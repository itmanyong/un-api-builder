    "oxfmt": "catalog:",
    "picocolors": "catalog:",
    "unconfig": "catalog:"
  },
  "devDependencies": {
    "@types/fs-extra": "catalog:",
    "@types/node": "catalog:",
    "jsdom": "catalog:",
    "bumpp": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {}
}
